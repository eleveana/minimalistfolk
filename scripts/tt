#!/usr/bin/env python3
"""tt — time tracker for the minimalist project, backed by ClickUp.

Usage:
  tt start "<description>" [--task <clickup_task_id>] [--billable]
  tt stop
  tt status
  tt log [--today | --week | --since YYYY-MM-DD]
  tt report [--week | --month | --since YYYY-MM-DD]
  tt tasks [--query <text>]

Config: project-root/.env  (see .env.example)
"""

import argparse
import json
import os
import sys
import urllib.parse
import urllib.request
from datetime import datetime, timedelta, timezone
from pathlib import Path

API_BASE = "https://api.clickup.com/api/v2"
PROJECT_ROOT = Path(__file__).resolve().parent.parent
ENV_PATH = PROJECT_ROOT / ".env"
STATE_DIR = Path.home() / ".config" / "minimalist-tt"
STATE_PATH = STATE_DIR / "state.json"


def load_env():
    if not ENV_PATH.exists():
        die(f"Missing {ENV_PATH}. Copy .env.example to .env and fill in values.")
    env = {}
    for line in ENV_PATH.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        env[k.strip()] = v.strip().strip('"').strip("'")
    for k in ("CLICKUP_API_TOKEN", "CLICKUP_TEAM_ID"):
        if not env.get(k):
            die(f"{k} not set in .env")
    return env


def die(msg, code=1):
    print(f"tt: {msg}", file=sys.stderr)
    sys.exit(code)


def api(env, method, path, params=None, body=None):
    url = f"{API_BASE}{path}"
    if params:
        url += "?" + urllib.parse.urlencode(params)
    headers = {"Authorization": env["CLICKUP_API_TOKEN"], "Content-Type": "application/json"}
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req) as r:
            return json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        msg = e.read().decode(errors="ignore")
        die(f"ClickUp API {e.code}: {msg}")


def now_ms():
    return int(datetime.now(timezone.utc).timestamp() * 1000)


def fmt_duration(ms):
    secs = ms // 1000
    h, rem = divmod(secs, 3600)
    m, s = divmod(rem, 60)
    return f"{h}h{m:02d}m" if h else f"{m}m{s:02d}s"


def fmt_local(ms):
    return datetime.fromtimestamp(int(ms) / 1000).strftime("%Y-%m-%d %H:%M")


def load_state():
    if not STATE_PATH.exists():
        return {}
    return json.loads(STATE_PATH.read_text())


def save_state(state):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(json.dumps(state, indent=2))


def cmd_start(args, env):
    state = load_state()
    if state.get("running"):
        die(f"Timer already running: \"{state['running']['description']}\" (started {fmt_local(state['running']['start'])}). Run `tt stop` first.")

    body = {
        "description": args.description,
        "billable": args.billable,
        "start": now_ms(),
    }
    if args.task:
        body["tid"] = args.task
    resp = api(env, "POST", f"/team/{env['CLICKUP_TEAM_ID']}/time_entries/start", body=body)
    entry = resp.get("data", {})
    state["running"] = {
        "id": entry.get("id"),
        "description": args.description,
        "task": args.task,
        "start": entry.get("start", body["start"]),
    }
    save_state(state)
    print(f"Started: \"{args.description}\"" + (f" → task {args.task}" if args.task else ""))


def cmd_stop(args, env):
    state = load_state()
    if not state.get("running"):
        die("No timer running.")
    resp = api(env, "POST", f"/team/{env['CLICKUP_TEAM_ID']}/time_entries/stop")
    entry = resp.get("data", {})
    duration = int(entry.get("duration", 0))
    print(f"Stopped: \"{state['running']['description']}\" — {fmt_duration(duration)}")
    state.pop("running", None)
    save_state(state)


def cmd_status(args, env):
    state = load_state()
    running = state.get("running")
    if not running:
        print("No timer running.")
        return
    elapsed = now_ms() - int(running["start"])
    suffix = f" → task {running['task']}" if running.get("task") else ""
    print(f"Running: \"{running['description']}\"{suffix}")
    print(f"  Started: {fmt_local(running['start'])}")
    print(f"  Elapsed: {fmt_duration(elapsed)}")


def _range_from_args(args):
    end = datetime.now(timezone.utc)
    if args.since:
        start = datetime.strptime(args.since, "%Y-%m-%d").replace(tzinfo=timezone.utc)
    elif args.week:
        start = (end - timedelta(days=end.weekday())).replace(hour=0, minute=0, second=0, microsecond=0)
    elif args.month:
        start = end.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
    else:
        start = end.replace(hour=0, minute=0, second=0, microsecond=0)
    return int(start.timestamp() * 1000), int(end.timestamp() * 1000)


def _fetch_entries(env, start_ms, end_ms):
    resp = api(env, "GET", f"/team/{env['CLICKUP_TEAM_ID']}/time_entries",
               params={"start_date": start_ms, "end_date": end_ms})
    return resp.get("data", [])


def cmd_log(args, env):
    start_ms, end_ms = _range_from_args(args)
    entries = _fetch_entries(env, start_ms, end_ms)
    if not entries:
        print("No entries in range.")
        return
    total = 0
    for e in sorted(entries, key=lambda x: int(x.get("start", 0))):
        dur = int(e.get("duration", 0))
        total += dur
        desc = e.get("description") or "(no description)"
        task = (e.get("task") or {}).get("name", "")
        task_suffix = f"  [{task}]" if task else ""
        print(f"{fmt_local(e['start'])}  {fmt_duration(dur):>8}  {desc}{task_suffix}")
    print(f"\nTotal: {fmt_duration(total)}  ({total / 3_600_000:.2f}h)")


def cmd_report(args, env):
    start_ms, end_ms = _range_from_args(args)
    entries = _fetch_entries(env, start_ms, end_ms)
    if not entries:
        print("No entries in range.")
        return
    by_desc = {}
    total = 0
    for e in entries:
        dur = int(e.get("duration", 0))
        total += dur
        key = e.get("description") or "(no description)"
        by_desc[key] = by_desc.get(key, 0) + dur
    for desc, dur in sorted(by_desc.items(), key=lambda kv: -kv[1]):
        print(f"  {fmt_duration(dur):>8}  ({dur / 3_600_000:>5.2f}h)  {desc}")
    print(f"\nTotal: {fmt_duration(total)}  ({total / 3_600_000:.2f}h)")


def cmd_tasks(args, env):
    if not env.get("CLICKUP_LIST_ID"):
        die("CLICKUP_LIST_ID not set in .env (needed for `tt tasks`).")
    resp = api(env, "GET", f"/list/{env['CLICKUP_LIST_ID']}/task", params={"archived": "false"})
    tasks = resp.get("tasks", [])
    q = (args.query or "").lower()
    for t in tasks:
        name = t.get("name", "")
        if q and q not in name.lower():
            continue
        status = (t.get("status") or {}).get("status", "")
        print(f"  {t['id']:>10}  [{status:<12}]  {name}")


def build_parser():
    p = argparse.ArgumentParser(prog="tt", description="Time tracker for minimalist (ClickUp-backed)")
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("start", help="Start a timer")
    s.add_argument("description", help="What you're working on")
    s.add_argument("--task", help="ClickUp task id to attach to")
    s.add_argument("--billable", action="store_true", default=True)
    s.set_defaults(fn=cmd_start)

    s = sub.add_parser("stop", help="Stop the running timer")
    s.set_defaults(fn=cmd_stop)

    s = sub.add_parser("status", help="Show running timer")
    s.set_defaults(fn=cmd_status)

    for name, fn in (("log", cmd_log), ("report", cmd_report)):
        s = sub.add_parser(name, help=f"Show {name} for a date range")
        s.add_argument("--today", action="store_true")
        s.add_argument("--week", action="store_true")
        s.add_argument("--month", action="store_true")
        s.add_argument("--since", help="YYYY-MM-DD")
        s.set_defaults(fn=fn)

    s = sub.add_parser("tasks", help="List ClickUp tasks in the configured list")
    s.add_argument("--query", help="Filter by substring")
    s.set_defaults(fn=cmd_tasks)

    return p


def main():
    args = build_parser().parse_args()
    env = load_env()
    args.fn(args, env)


if __name__ == "__main__":
    main()
